      weatherRestrictionType : TEXT*255;
      weightBearingCapacity : 0.000 .. 999999999.999;
    END TurnaroundSite;

    CLASS VehicleBarrier EXTENDS DGIF_V3.Foundation.FeatureEntity =
      conspicuousAirCategory : TEXT*255;
      conspicuousGroundCategory : TEXT*255;
      conspicuousSeaCategory : TEXT*255;
      elevationMsl : 0.000 .. 999999999.999;
      facilityOperationalStatus : TEXT*255;
      heightAboveSurfaceLevel : TEXT*255;
      highestElevation : TEXT*255;
      meansTransportation : BAG OF TEXT*255;
      permanent : BOOLEAN;
      physicalCondition : TEXT*255;
      structMatType : BAG OF TEXT*255;
      waterLevelEffect : TEXT*255;
    END VehicleBarrier;

    CLASS VesselLift EXTENDS DGIF_V3.Cultural.NonBuildingStructure =
      liftingCapacity : 0.000 .. 999999999.999;
    END VesselLift;

    CLASS WeighStation EXTENDS DGIF_V3.Cultural.Facility =
      vehicleScaleCount : -2000000000 .. 2000000000;
    END WeighStation;

    ASSOCIATION RailwayTunnel =
      passesThrough -- {0..*} Tunnel;
      containedRailway -- {0..*} Railway;
    END RailwayTunnel;

    ASSOCIATION RailwayBridgeSpan =
      supportedBy -- {0..*} BridgeSpan;
      supportsRailway -- {0..*} Railway;
    END RailwayBridgeSpan;

  END Transportation;

END DGIF_V3.

